{
  "name": "@captain/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "build": "node scripts/run-prisma.mjs generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "db:generate": "node scripts/run-prisma.mjs generate",
    "db:migrate": "node scripts/run-prisma.mjs migrate dev",
    "db:migrate:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:push": "node scripts/run-prisma.mjs db push",
    "db:studio": "node scripts/run-prisma.mjs studio",
    "db:seed": "node scripts/run-prisma.mjs db seed",
    "db:demo-reset": "tsx scripts/distribution-demo-reset.ts"
  },
  "dependencies": {
    "@captain/shared": "0.1.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}

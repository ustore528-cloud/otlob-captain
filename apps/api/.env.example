NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/order_captain?schema=public"
JWT_SECRET="change-me-min-16-chars-for-backward-compat"
JWT_ACCESS_SECRET="change-me-access-secret-min-16"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-16"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:5173"
DISTRIBUTION_TIMEOUT_SECONDS=30
DISTRIBUTION_POLL_MS=5000
DISTRIBUTION_MAX_ATTEMPTS=30

NODE_ENV=development
# بعد `npm run db:seed`: كابتن معاينة +966599999991 | كلمة المرور Admin12345! (وباقي المستخدمين التجريبيين بنفسها)
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/order_captain?schema=public"
# Optional: Railway/prod read-only from your machine (CLI tools). Overrides DATABASE_URL for Prisma when set in the shell.
# REMOTE_DATABASE_URL="postgresql://..."
# Same token the production API uses for https://exp.host/--/api/v2/push/send (Expo dashboard → Access Token).
# EXPO_PUSH_ACCESS_TOKEN=
JWT_SECRET="change-me-min-16-chars-for-backward-compat"
JWT_ACCESS_SECRET="change-me-access-secret-min-16"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-16"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# للتطوير مع تطبيق الموبايل على شبكة محلية استخدم * (أو أضف أصولًا صريحة). القيمة الافتراضية السابقة كانت للويب فقط.
CORS_ORIGIN="*"
# إنتاج / Railway: إن أردت Preview منفصل عن سطر `CORS_ORIGIN` ضع دوامين Vercel هنا مفصولة بفاصلة، مثل:
# CORS_EXTRA_ORIGINS="https://web-xxxxx-xxxxx-xxxxx-xxxxx-xxxxxx.vercel.app"
CORS_EXTRA_ORIGINS=""
# Offer confirmation window is fixed at 30s in code (OFFER_CONFIRMATION_WINDOW_SECONDS). Not env-configurable.
# Set to 1 to log [offer-diagnostics] lines on stdout when creating/reading offers (single-test trace).
OFFER_DIAGNOSTICS=0
DISTRIBUTION_POLL_MS=2000
DISTRIBUTION_MAX_ATTEMPTS=30

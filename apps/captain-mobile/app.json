{
  "expo": {
    "name": "اطلب كابتن",
    "slug": "captain-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "captain",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.captain.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نستخدم موقعك لعرضك على خريطة التوزيع ولتتبع الطلبات النشطة.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "للتتبع أثناء التوصيل عند تفعيل الخلفية لاحقًا."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.captain.mobile",
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false }
    }
  }
}

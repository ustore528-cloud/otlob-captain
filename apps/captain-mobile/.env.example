# انسخ هذا الملف إلى `.env` في نفس المجلد ثم أعد تشغيل Metro (`npx expo start`).
# المتغيرات التي تبدأ بـ EXPO_PUBLIC تُدمَج في الباندل وقت التشغيل/البناء.

# عنوان الـ API (REST + Socket.IO على نفس الأصل). بدون شرطة مائلة في النهاية.
#
# ┌─────────────────────┬────────────────────────────────────────────────────────┐
# │ السيناريو           │ مثال                                                    │
# ├─────────────────────┼────────────────────────────────────────────────────────┤
# │ جهاز حقيقي (LAN)    │ http://192.168.1.10:4000  (استبدل بـ IP جهازك المضيف)   │
# │ محاكي Android       │ http://10.0.2.2:4000                                    │
# │ محاكي iOS / جهاز    │ http://localhost:4000 (غالبًا يعمل على محاكي iOS فقط)     │
# └─────────────────────┴────────────────────────────────────────────────────────┘
#
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

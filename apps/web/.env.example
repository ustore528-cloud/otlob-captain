# Copy to `.env` and adjust. For `npm run dev`, prefer empty VITE_API_URL so requests stay on the Vite dev server and proxy to the local API.

# Empty = same-origin + Vite proxy (see vite.config.ts) → local API on port 4000
VITE_API_URL=
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:4000
VITE_SOCKET_URL=

# --- Production / remote API (build with env in CI or use .env.production) ---
# VITE_API_URL=https://your-api.example.com
# VITE_API_PROXY_TARGET=https://your-api.example.com
